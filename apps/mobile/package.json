    "babel-preset-expo": "~57.0.1",
    "eslint": "^9.5.0",
    "globals": "^15.6.0",
    "prettier": "^3.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  }
