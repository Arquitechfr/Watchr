    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.5.0",
    "globals": "^15.6.0",
    "mongodb-memory-server": "^9.4.0",
    "prettier": "^3.3.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
