{
  "name": "@watchr/backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/server.ts",
    "build": "tsc",
    "start": "node --import ./dist/instrument.js dist/server.js",
    "worker": "tsx watch --import ./src/instrument.ts src/workers/startImportWorker.ts",
    "sync": "tsx watch --import ./src/instrument.ts src/workers/startEpisodeSyncWorker.ts",
    "sync-all-episodes": "tsx scripts/sync-all-episodes.ts",
    "notifications": "tsx scripts/sendNotifications.ts",
    "notifications-worker": "tsx watch --import ./src/instrument.ts src/workers/startNotificationWorker.ts",
    "news-worker": "tsx watch --import ./src/instrument.ts src/workers/startNewsSyncWorker.ts",
    "username-fix-worker": "tsx watch --import ./src/instrument.ts src/workers/startUsernameFixWorker.ts",
    "ban-scheduler-worker": "tsx watch --import ./src/instrument.ts src/workers/startBanSchedulerWorker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "mobile-config": "tsx scripts/mobile-config-cli.ts",
    "mobile-config:seed": "tsx scripts/mobile-config-seed.ts",
    "promote-admin": "tsx src/scripts/promote-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@mistralai/mistralai": "^2.4.1",
    "@sentry/node": "^10.63.0",
    "@sentry/profiling-node": "^10.63.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "adm-zip": "^0.5.12",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "fast-xml-parser": "^5.9.3",
    "fastest-levenshtein": "^1.0.16",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.1.0",
    "html-entities": "^2.6.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.3",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.14",
    "p-limit": "^7.3.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/adm-zip": "^0.5.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.5.0",
    "globals": "^15.6.0",
    "mongodb-memory-server": "^9.4.0",
    "prettier": "^3.3.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  }
}
