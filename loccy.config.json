// https://loccy.dev - AI-powered IDE extension to manage i18n with ease
{
  "resources": {
    "paths": {
      "include": [
        "apps/mobile/src/i18n/translations.ts",
        "apps/backend/src/i18n/translations.ts"
      ],
      "exclude": [
        "**/node_modules/**"
      ]
    },
    "file": {
      "structure": "nested",
      "sortKeys": "auto"
    }
  },
  "usages": {
    "paths": {
      "include": [
        "apps/mobile/src/**/*.{ts,tsx}",
        "apps/backend/src/**/*.ts"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/i18n/translations.ts"
      ]
    },
    "tFunction": {
      "preset": "none",
      "customFunctionNames": [
        "t",
        "translate",
        "translateError",
        "translateNotification",
        "translateEmail"
      ]
    },
    "detectKeysInStrings": true,
    "quoteType": "double"
  }
}