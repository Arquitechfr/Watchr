{
  "expo": {
    "name": "Watchr",
    "slug": "watchr",
    "scheme": "watchr",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.watchr.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.watchr.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "326c4789-7383-4a4c-9cd7-202f4bc90faf"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "./plugins/withCustomSplashScreen",
      "expo-localization",
      "expo-notifications",
      "expo-dev-client",
      "@react-native-google-signin/google-signin",
      [
        "@sentry/react-native/expo",
        {
          "dsn": "https://bf2e227cd3abf6f8e316e40c13f874dc@o4511684973428736.ingest.de.sentry.io/4511684992893008",
          "organization": "arquitech-fq",
          "project": "watchr-expo"
        }
      ],
      "@sentry/react-native",
      "expo-sharing"
    ],
    "owner": "arquitech"
  }
}
