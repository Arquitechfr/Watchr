    "helmet": "^7.1.0",
    "html-entities": "^2.6.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "p-limit": "^7.3.0",
    "posthog-node": "^5.41.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^6.0.0",
    "react": "^19.0.0",
