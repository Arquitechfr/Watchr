{
  "name": "@watchr/backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "node scripts/prepare-deploy.mjs",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "tsx watch src/workers/startImportWorker.ts",
    "sync": "tsx watch src/workers/startEpisodeSyncWorker.ts",
    "sync-all-episodes": "tsx scripts/sync-all-episodes.ts",
    "purge-corrupted-translations": "tsx scripts/purge-corrupted-translations.ts",
    "notifications": "tsx scripts/sendNotifications.ts",
    "notifications-worker": "tsx watch src/workers/startNotificationWorker.ts",
    "news-worker": "tsx watch src/workers/startNewsSyncWorker.ts",
    "reengagement-worker": "tsx watch src/workers/startReengagementWorker.ts",
    "activation-nudge-worker": "tsx watch src/workers/startActivationNudgeWorker.ts",
    "username-fix-worker": "tsx watch src/workers/startUsernameFixWorker.ts",
    "ban-scheduler-worker": "tsx watch src/workers/startBanSchedulerWorker.ts",
    "email-worker": "tsx watch src/workers/startEmailWorker.ts",
    "moderation-worker": "tsx watch src/workers/startModerationWorker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "mobile-config": "tsx scripts/mobile-config-cli.ts",
    "mobile-config:seed": "tsx scripts/mobile-config-seed.ts",
    "promote-admin": "tsx src/scripts/promote-admin.ts",
