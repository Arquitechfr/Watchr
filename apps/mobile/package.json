{
  "name": "@watchr/mobile",
  "version": "0.1.0",
  "main": "expo/AppEntry.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "dev": "expo start --dev-client",
    "dev:clear": "expo prebuild && expo start --dev-client --clear",
    "prebuild": "expo prebuild",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web --output-dir dist && node scripts/post-web-build.cjs",
    "lint": "eslint src/ App.tsx",
    "typecheck": "tsc --noEmit",
    "eas-build-pre-install": "bash scripts/eas-build-pre-install.sh"
  },
  "dependencies": {
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/metro-runtime": "^57.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@posthog/react-native-plugin": "^2.2.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.18.5",
    "@react-navigation/native": "^7.3.5",
    "@react-navigation/native-stack": "^7.17.7",
    "@tanstack/react-query": "^5.45.1",
    "@watchr/i18n-languages": "workspace:*",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "expo": "~57.0.7",
    "expo-application": "~57.0.2",
    "expo-auth-session": "^57.0.4",
    "expo-build-properties": "^57.0.6",
    "expo-clipboard": "^57.0.1",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "^57.0.1",
    "expo-image-picker": "^57.0.5",
    "expo-in-app-updates": "^0.12.0",
    "expo-linear-gradient": "^57.0.1",
    "expo-localization": "~57.0.1",
    "expo-notifications": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "^57.0.1",
    "firebase": "^12.15.0",
    "i18n-js": "^4.5.3",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^4.56.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-helmet-async": "^3.0.0",
    "react-native": "0.86.0",
    "react-native-android-widget": "^0.20.3",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
