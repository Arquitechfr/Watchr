{
  "expo": {
    "name": "Watchr",
    "slug": "watchr",
    "scheme": "watchr",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.watchr.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.watchr.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "extra": {
      "eas": {
        "projectId": "326c4789-7383-4a4c-9cd7-202f4bc90faf"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "./plugins/withCustomSplashScreen",
      "./plugins/withAppLinks",
      "expo-localization",
      "expo-notifications",
      "expo-dev-client",
      "@react-native-google-signin/google-signin",
      [
        "@sentry/react-native/expo",
        {
          "dsn": "https://bf2e227cd3abf6f8e316e40c13f874dc@o4511684973428736.ingest.de.sentry.io/4511684992893008",
          "organization": "arquitech-fq",
          "project": "watchr-expo"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "UpNext",
              "label": "Watchr Up Next",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000,
              "description": "Episodes to watch & upcoming releases"
            }
          ]
        }
      ],
      "@sentry/react-native",
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableBundleCompression": true,
            "extraProguardRules": "\n# Sentry\n-keep class io.sentry.** { *; }\n-dontwarn io.sentry.**\n\n# Firebase / Google Sign-In\n-keep class com.google.firebase.** { *; }\n-keep class com.google.android.gms.** { *; }\n-dontwarn com.google.firebase.**\n-dontwarn com.google.android.gms.**\n\n# react-native-android-widget\n-keep class com.reactnativeandroidwidget.** { *; }\n\n# Socket.io\n-keep class io.socket.** { *; }\n-dontwarn io.socket.**\n\n# React Native bridge & Hermes\n-keep class com.facebook.react.** { *; }\n-keep class com.facebook.hermes.** { *; }\n\n# Gson serialization\n-keepclassmembers,allowobfuscation class * {\n  @com.google.gson.annotations.SerializedName <fields>;\n}\n"
          }
        }
      ]
    ],
    "owner": "arquitech"
  }
}
